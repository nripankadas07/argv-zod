{
  "name": "argv-zod",
  "version": "0.1.0",
  "description": "Type-safe argv parser with a Zod-style fluent schema builder. Inferred result types, env-var fallbacks, aliases, defaults, choices, and per-field validation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "argv",
    "argument-parser",
    "cli",
    "command-line",
    "schema",
    "zod",
    "typescript",
    "type-safe"
  ],
  "author": "nripankadas07",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nripankadas07/argv-zod.git"
  },
  "bugs": {
    "url": "https://github.com/nripankadas07/argv-zod/issues"
  },
  "homepage": "https://github.com/nripankadas07/argv-zod#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
